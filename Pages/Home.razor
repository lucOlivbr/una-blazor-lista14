@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Felix" class="rounded-circle mb-3"
                     width="120" />
                <h3>Lucas Alves Oliveira</h3>
                <p class="text-muted">Desenvolvedor Backend</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Una Barreiro",
            Cargo = "Estudante",
            Inicio = "2026",
            Descricao = "Estudante de Ciência da Computação. Início do curso em 2026."
        },
        new Experiencia {
            Empresa = "Iniciativa Pessoal",
            Cargo = "Freelancer",
            Inicio = "2024", Fim = "2024",
            Descricao = "Criação de landing pages para comércios locais."
        }
    };
}